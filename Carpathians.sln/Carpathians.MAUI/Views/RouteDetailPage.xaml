<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Carpathians.MAUI.ViewModels"
             x:Class="Carpathians.MAUI.Views.RouteDetailPage"
             Title="{Binding Title}"
             BackgroundColor="#050a09"
             Padding="0,0,0,0">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1B2E2B" Offset="0"/>
            <GradientStop Color="#050a09" Offset="1"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView Margin="0,0,0,80">
        <VerticalStackLayout>
            <Grid HeightRequest="250">
                <Image Source="{Binding CurrentRoute.MapImage}" Aspect="AspectFill"/>
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#050a09" Offset="1"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>
                <Label Text="{Binding CurrentRoute.Title}" FontFamily="DMSerif" FontSize="32" TextColor="White" VerticalOptions="End" Margin="20"/>
            </Grid>
            
            <HorizontalStackLayout Spacing="20" Margin="20,0">
                <Label Text="{Binding CurrentRoute.Difficulty}" TextColor="{Binding CurrentRoute.DifficultyColor}"/>
                <Label Text="{Binding CurrentRoute.Length, StringFormat='→ {0}'}" TextColor="#bbbbbb"/>
                <Label Text="{Binding CurrentRoute.Duration, StringFormat='⏱ {0}'}" TextColor="#bbbbbb"/>
            </HorizontalStackLayout>
            
            <Button Text="ЗАПИСАТИСЬ НА МАРШРУТ" Style="{StaticResource BtnGreen}" Margin="20" Command="{Binding GoToBookingCommand}"/>
            <Button Text="КАРТА МАРШРУТУ" Style="{StaticResource BtnCTA}" Margin="20,0,20,20" Command="{Binding OpenMapCommand}"/>

            <Label Text="ТОЧКИ МАРШРУТУ" FontFamily="DMSerif" FontSize="20" TextColor="White" Margin="20,10,20,10"/>
            <CollectionView ItemsSource="{Binding Points}" Margin="20,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="40,*" Margin="0,0,0,20">
                            <BoxView Grid.Column="0" WidthRequest="2" BackgroundColor="#2e7d32" HorizontalOptions="Center" VerticalOptions="Fill"/>
                            <Border Grid.Column="0" WidthRequest="16" HeightRequest="16" StrokeShape="RoundRectangle 8" BackgroundColor="#2e7d32" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,4,0,0"/>
                            
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="{Binding Title}" TextColor="White" FontSize="18" FontFamily="DMSerif"/>
                                <Label Text="{Binding Altitude, StringFormat='Висота: {0}'}" TextColor="#4CAF50" FontSize="12"/>
                                
                                <VerticalStackLayout Padding="12,8" Spacing="10" BackgroundColor="#33000000" Margin="0,8,0,0">
                                    <Label Text="{Binding Description}"
                                           FontSize="14"
                                           TextColor="#cccccc"
                                           FontAttributes="Italic"
                                           LineBreakMode="WordWrap"/>

                                    <Grid IsVisible="{Binding HasImage}" HeightRequest="180">
                                        <Border StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                            <Image Source="{Binding Image}" Aspect="AspectFill" HeightRequest="180"/>
                                        </Border>
                                    </Grid>

                                    <!-- Зберігаємо fallback кнопку про всяк випадок, хоча фото вантажиться локально -->
                                    <Button Text="📷 Показати фото"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RouteDetailViewModel}}, Path=ShowPhotoCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#22ffffff"
                                            TextColor="White"
                                            FontSize="13"
                                            CornerRadius="10"
                                            Padding="8,6"
                                            IsVisible="{Binding HasImage}"/>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>