<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:Carpathians.MAUI.Views"
       x:Class="Carpathians.MAUI.AppShell"
       Shell.TabBarBackgroundColor="#D9000000"
       Shell.TabBarForegroundColor="#4CAF50"
       Shell.TabBarUnselectedColor="#bbbbbb"
       Shell.TabBarTitleColor="#4CAF50">

    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.TabBarBackgroundColor" Value="#D9000000"/>
            <Setter Property="Shell.TabBarForegroundColor" Value="#4CAF50"/>
            <Setter Property="Shell.TabBarUnselectedColor" Value="#bbbbbb"/>
        </Style>
    </Shell.Resources>

    <TabBar>
        <Tab Title="Маршрути">
            <Tab.Icon>
                <FontImageSource FontFamily="OpenSansRegular" Glyph="&#x2295;" Color="#bbbbbb" Size="22"/>
            </Tab.Icon>
            <ShellContent
                Title="Маршрути"
                ContentTemplate="{DataTemplate views:RoutesPage}"
                Route="routes"
                Shell.NavBarIsVisible="False"/>
        </Tab>

        <Tab Title="Записатись">
            <Tab.Icon>
                <FontImageSource FontFamily="OpenSansRegular" Glyph="&#x2606;" Color="#bbbbbb" Size="22"/>
            </Tab.Icon>
            <ShellContent
                Title="Записатись"
                ContentTemplate="{DataTemplate views:BookingPage}"
                Route="booking"
                Shell.NavBarIsVisible="False"/>
        </Tab>

        <Tab Title="Галерея">
            <Tab.Icon>
                <FontImageSource FontFamily="OpenSansRegular" Glyph="&#x25A3;" Color="#bbbbbb" Size="22"/>
            </Tab.Icon>
            <ShellContent
                Title="Галерея"
                ContentTemplate="{DataTemplate views:GalleryPage}"
                Route="gallery"
                Shell.NavBarIsVisible="False"/>
        </Tab>

        <Tab Title="Профіль">
            <Tab.Icon>
                <FontImageSource FontFamily="OpenSansRegular" Glyph="&#x263A;" Color="#bbbbbb" Size="22"/>
            </Tab.Icon>
            <ShellContent
                Title="Профіль"
                ContentTemplate="{DataTemplate views:ProfilePage}"
                Route="profile"
                Shell.NavBarIsVisible="False"/>
        </Tab>
    </TabBar>
</Shell>